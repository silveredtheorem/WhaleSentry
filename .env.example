# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000

# ─── Binance pairs (comma-separated Binance symbol format) ───────────────────
PAIRS=btcusdt,ethusdt,bnbusdt

# ─── Detection window ────────────────────────────────────────────────────────
# Aggregated-window detection: sum trades over this many milliseconds
AGG_WINDOW_MS=5000

# Minimum gap between aggregated alerts per pair
MIN_EMIT_GAP_MS=5000

# Consumer drain interval (how often the ring buffer is flushed)
TRADE_CONSUMER_INTERVAL_MS=50

# ─── Ring buffer ─────────────────────────────────────────────────────────────
TRADE_QUEUE_CAPACITY=2000

# ─── Rolling z-score (Welford's algorithm) ───────────────────────────────────
ROLLING_WINDOW_SIZE=500     # samples kept per symbol
ROLLING_MIN_SAMPLES=30      # minimum samples before z-score is emitted
Z_SCORE_CUTOFF=3.0          # standard deviations to flag as DOLPHIN

# ─── Order book imbalance ────────────────────────────────────────────────────
DEPTH_LEVELS=5
# Minimum |imbalance| to consider the book directionally biased
IMBALANCE_THRESHOLD=0.2

# ─── Static dollar thresholds ────────────────────────────────────────────────
THRESHOLD_DOLPHIN=200000
THRESHOLD_WHALE=500000
THRESHOLD_MEGALODON=1000000

# ─── History ─────────────────────────────────────────────────────────────────
MAX_HISTORY=3600            # trade events kept in memory for new-client replay
